# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.db
*.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - 機密情報保護のため除外
.env
.env.local
.env.production
.env.development
.env.test
.env.*.local

# 例外: 機密情報を含まない環境変数例
!.env.example
!.env.template

# Vercel環境変数（機密情報含む可能性）
.vercel/.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# PWA
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
