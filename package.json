{
  "name": "fridge-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "fix:lint": "eslint . --fix || exit 0",
    "fix:format": "prettier --write . || exit 0",
    "check:types": "tsc --noEmit || exit 0",
