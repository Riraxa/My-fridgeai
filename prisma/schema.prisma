generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  createdAt            DateTime  @default(now())
  status               String?   @default("active")
  verifyToken          String?
  verifyTokenCreatedAt DateTime?
  verifyCode           String?
  verifyExpires        DateTime?
  allowedIps           String[]
  aiMenuCount          Int       @default(0) @map("ai_menu_count")
  aiMenuLastReset      DateTime? @map("ai_menu_last_reset")
  aiDailyCount         Int       @default(0)
  dailyBarcodeCount    Int       @default(0)
  dailyResetAt         DateTime?
  authMethod           String    @default("password_only") @map("auth_method")

  @@index([email, status])
  @@index([createdAt])
  @@index([plan])
  @@index([stripeCustomerId])

  shoppingListItems ShoppingListItem[]

  // ===== Stripe / Paid plan =====
  plan                   PlanType       @default(FREE)
  planExpiresAt          DateTime?
  stripeCustomerId       String?        @unique
  billingStatus          String?
  passkeySetupCompleted  Boolean?       @default(false)
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  cancelAtPeriodEnd      Boolean        @default(false)
  subscriptions          Subscription[]

  // Household 関連
  householdsOwned     Household[]       @relation("Owner")
  householdMembership HouseholdMember[]

  // relations
  accounts          Account[]
  AuthChallenges    AuthChallenge[]
  EmailVerification EmailVerification[] @relation("UserEmailVerification")
  Favorite          Favorite[]
  Ingredient        Ingredient[]
  Menu              Menu[]
  passkeys          Passkey[]
  PasswordReset     PasswordReset[]
  products          Product[]
  sessions          Session[]
  TrustedDevice     TrustedDevice[]
  UsageHistory      UsageHistory[]
  BillingEvents     BillingEvent[]

  // New Relations for Menu Generation
  menuGenerations       MenuGeneration[]
  weeklyMenuGenerations WeeklyMenuGeneration[]
  cookingHistory        CookingHistory[]
  inventoryAlerts       InventoryAlert[]
  preferences           UserPreferences?
  allergies             UserAllergy[]
  restrictions          UserRestriction[]
}

enum PlanType {
  FREE
  PRO
}

enum IngredientType {
  raw                // 通常食材
  processed_base     // 他食材と組み合わせる前提の商品（カレールー等）
  instant_complete   // 単体で完成する商品（即席味噌汁等）
}

model Household {
  id        String            @id @default(cuid())
  ownerId   String
  owner     User              @relation("Owner", fields: [ownerId], references: [id])
  members   HouseholdMember[]
  invites   HouseholdInvite[]
  createdAt DateTime          @default(now())
}

model HouseholdInvite {
  id          String   @id @default(cuid())
  householdId String
  email       String?
  token       String   @unique
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}

enum HouseholdRole {
  OWNER
  MEMBER
}

model BillingEvent {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  payload   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// 仮登録ユーザー（メール検証待ち）
model PendingUser {
  id                String              @id @default(cuid())
  email             String              @unique
  name              String?
  password          String? // hashed password
  token             String?             @unique
  expiresAt         DateTime
  createdAt         DateTime            @default(now())
  // EmailVerification が pendingUserId を参照する可能性がある
  EmailVerification EmailVerification[]
}

/// WebAuthn passkey representation
model Passkey {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    String
  signCount    Int
  transports   String?
  name         String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Short-lived stored challenges for webauthn (authenticate without email flow)
model AuthChallenge {
  id        String    @id @default(cuid())
  challenge String    @unique
  userId    String?
  used      Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id            String       @id @default(cuid())
  userId        String? // legacy / post-verify: references User.id
  pendingUserId String? // new: references PendingUser.id (pre-verify)
  tokenHash     String       @unique
  code          String
  expiresAt     DateTime
  used          Boolean      @default(false)
  createdAt     DateTime     @default(now())
  user          User?        @relation("UserEmailVerification", fields: [userId], references: [id], onDelete: Cascade)
  pendingUser   PendingUser? @relation(fields: [pendingUserId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  deviceInfo String?
  createdAt  DateTime @default(now())
  lastUsed   DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenHash])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  menuId    String?
  title     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ingredient {
  id       String @id @default(cuid())
  userId   String
  name     String
  quantity Float  @default(0) // Keep for backward compatibility, but prefer 'amount'

  // New standardized fields
  amount      Float? // 数値（500）
  amountLevel String? // ざっくり（たっぷ, 普通, 少ない, ほぼない）
  unit        String? // 単位（ml, g, 個）

  // Expiration fields
  expirationDate      DateTime? @map("expiry") // Map to existing 'expiry' column if possible or start new. Existing schema has expiry DateTime?
  expirationEstimated Boolean   @default(false)

  category String?

  // 加工食品統合: ingredient_type
  ingredientType IngredientType @default(raw)
  productId      String?        // 加工食品の場合、Productに紐づく
  product        Product?       @relation(fields: [productId], references: [id])

  // Purchase info
  purchasedAt DateTime?
  barcode     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  alerts InventoryAlert[]

  @@index([userId, expirationDate])
  @@index([userId, createdAt])
  @@index([userId, category])
  @@index([barcode])
  @@index([ingredientType])
}

/// 加工食品マスター（ルー、即席食品、混合調味料など）
model Product {
  id        String   @id @default(cuid())
  userId    String
  name      String   // 商品名（例：バーモントカレー中辛）
  brandName String?  // ブランド名（例：ハウス食品）

  ingredientType IngredientType @default(processed_base)

  /// 必要追加食材（JSON）
  /// 例: [{"name":"玉ねぎ","amount":2,"unit":"個"},{"name":"じゃがいも","amount":2,"unit":"個"}]
  requiresAdditionalIngredients Json? @default("[]")

  /// 調理手順テンプレート
  /// processed_base: "商品操作手順に従い、◯◯を仕上げる"
  /// instant_complete: "商品操作手順に従い準備する"
  instructionTemplate String?

  /// 栄養推定値（任意）
  nutritionEstimate Json? // { calories, protein, fat, carbs }

  barcode   String?  // バーコード番号
  category  String?  // 商品カテゴリ（カレー、スープ等）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients Ingredient[]

  @@index([userId])
  @@index([barcode])
  @@index([ingredientType])
}

model Menu {
  id          String   @id @default(cuid())
  userId      String
  title       String
  difficulty  String?
  time        String?
  tips        String?
  ingredients Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageHistory {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @default(now())
  action String
  meta   Json?
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  stripeCustomerId     String
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShoppingListItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  quantity  Float    @default(1)
  unit      String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, checked])
}

// ==========================================
// New Models for Menu Generation
// ==========================================

model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique

  cookingSkill       String   @default("intermediate") // beginner | intermediate | advanced
  comfortableMethods String[] @default([])            // ["炒め物", "煮物", "焼き物"]
  avoidMethods       String[] @default([])            // ["揚げ物"]
  kitchenEquipment   String[] @default([])            // ["電子レンジ", "オーブン"]

  // Alert Settings
  enableExpirationAlert Boolean @default(true)
  alertDaysBefore       Int     @default(3)
  alertTime             String  @default("07:00") // Notification time

  // Advanced Expiration Controls (Pro)
  expirationCriticalDays   Int   @default(2) // "Critical" threshold
  expirationWarningDays    Int   @default(5) // "Warning" threshold
  expirationPriorityWeight Float @default(0.7) // Priority weight (0.0-1.0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Extended Preferences
  tasteJson           Json    @default("{}") // 味、設備、ライフスタイル等
  aiMessageEnabled    Boolean @default(false) // Pro向け: AIへの指示有効化
  proFeaturesUnlocked Boolean @default(false) // Pro向けフラグ

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAllergy {
  id        String   @id @default(cuid())
  userId    String
  allergen  String // e.g. "egg", "milk", "wheat"
  label     String? // 表示名（日本語）
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRestriction {
  id        String   @id @default(cuid())
  userId    String
  type      String // "vegetarian","vegan","halal","medical","other"
  note      String? // 自由記述（例：糖質制限中）
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyMenuGeneration {
  id                       String   @id @default(cuid())
  userId                   String
  startDate                DateTime
  endDate                  DateTime
  dailyMenus               Json // Array of 7 DailyMenuPlan
  consolidatedShoppingList Json // Array of strings or objects
  createdAt                DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MenuGeneration {
  id     String @id @default(cuid())
  userId String
  status String @default("completed") // completed | failed

  // Generated Menus (3 patterns)
  mainMenu     Json // Main proposal
  alternativeA Json // Alternative A
  alternativeB Json // Alternative B

  // User Selection
  selectedMenu String? // "main" | "altA" | "altB"

  // Context
  usedIngredients Json // [{ id, name, amount, unit }]
  shoppingList    Json // [{ name, amount, unit, reason }]

  // Metadata
  generatedAt DateTime @default(now())
  difficulty  Int? // 1-5

  // Pro Feature
  nutritionInfo Json? // { calories, protein, carbs, fat }

  // New Fields for Generation Conditions
  servings      Int      @default(1)
  budget        Int?     // 1食あたりの予算（nullの場合は指定なし）

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cookingHistory CookingHistory[]

  @@index([userId, generatedAt])
  @@index([status])
}

model CookingHistory {
  id               String  @id @default(cuid())
  userId           String
  menuGenerationId String?

  status   String   @default("completed") // completed | cancelled
  cookedAt DateTime @default(now())

  // Actual cooked dishes
  cookedDishes Json // ["Main", "Side"]

  // Snapshot of ingredients used
  usedIngredients Json

  // Cancellation window
  cancellableUntil DateTime

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuGeneration MenuGeneration? @relation(fields: [menuGenerationId], references: [id])

  @@index([userId, cookedAt])
}

model InventoryAlert {
  id           String @id @default(cuid())
  userId       String
  ingredientId String

  alertType String // "expiration" | "low-stock"
  alertDays Int     @default(3)
  isActive  Boolean @default(true)

  lastAlertedAt DateTime?
  createdAt     DateTime  @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([userId, ingredientId, alertType])
}
