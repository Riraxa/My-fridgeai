generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                 @id @default(cuid())
  name                   String?
  email                  String?                @unique
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime               @default(now())
  status                 String?                @default("active")
  // aiDailyCount/dailyResetAt are kept as DB fallback for Redis failure (Safety First)
  aiDailyCount           Int                    @default(0)
  dailyResetAt           DateTime?
  plan                   PlanType               @default(FREE)
  stripeCustomerId       String?                @unique
  billingStatus          String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  cancelAtPeriodEnd      Boolean                @default(false)
  onboardingCompleted    Boolean                @default(false) @map("onboarding_completed")
  accounts               Account[]
  cookingHistories       CookingHistory[]
  householdsOwned        Household[]            @relation("Owner")
  householdMembership    HouseholdMember[]
  Ingredient             Ingredient[]
  inventoryAlerts        InventoryAlert[]
  menuGenerations        MenuGeneration[]
  products               Product[]
  receipts               Receipt[]
  sessions               Session[]
  shoppingListItems      ShoppingListItem[]
  UsageHistory           UsageHistory[]
  TelemetryEvent         TelemetryEvent[]
  allergies              UserAllergy[]
  preferences            UserPreferences?
  restrictions           UserRestriction[]
  weeklyMenuGenerations  WeeklyMenuGeneration[]
  pushSubscriptions      PushSubscription[]
  chatDailyQuota         ChatDailyQuota?

  @@index([createdAt], map: "idx_user_createdat")
  @@index([plan], map: "idx_user_plan")
}

model Household {
  id        String            @id @default(cuid())
  ownerId   String
  createdAt DateTime          @default(now())
  owner     User              @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invites   HouseholdInvite[]
  members   HouseholdMember[]
  receipts  Receipt[]
}

model HouseholdInvite {
  id          String    @id @default(cuid())
  householdId String
  token       String    @unique
  expiresAt   DateTime
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([provider, providerAccountId], map: "ux_account_provider_provideraccountid")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model Ingredient {
  id                  String           @id @default(cuid())
  userId              String
  name                String
  amount              Float?
  unit                String?
  expirationDate      DateTime?        @map("expiry")
  expirationEstimated Boolean          @default(false)
  category            String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  ingredientType      IngredientType   @default(raw)
  productId           String?
  product             Product?         @relation(fields: [productId], references: [id])
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts              InventoryAlert[]
  receiptItems        ReceiptItem[]

  @@index([userId, expirationDate])
  @@index([ingredientType])
  @@index([userId, category], map: "idx_ingredient_user_category")
  @@index([userId, createdAt], map: "idx_ingredient_user_createdat")
  @@index([userId, expirationDate], map: "idx_ingredient_user_expiry")
}

/// 加工食品マスター（ルー、即席食品、混合調味料など）
model Product {
  id                            String         @id @default(cuid())
  userId                        String
  name                          String
  brandName                     String?
  ingredientType                IngredientType @default(processed_base)
  /// 必要追加食材（JSON）
  /// 例: [{"name":"玉ねぎ","amount":2,"unit":"個"},{"name":"じゃがいも","amount":2,"unit":"個"}]
  requiresAdditionalIngredients Json?          @default("[]")
  /// 調理手順テンプレート
  /// processed_base: "商品操作手順に従い、◯◯を仕上げる"
  /// instant_complete: "商品操作手順に従い準備する"
  instructionTemplate           String?
  /// 栄養推定値（任意）
  nutritionEstimate             Json?
  category                      String?
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @default(now()) @updatedAt
  ingredients                   Ingredient[]
  user                          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ingredientType])
}


model UsageHistory {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @default(now())
  action String
  meta   Json?
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// 分析用テレメトリイベント
model TelemetryEvent {
  id        String   @id @default(cuid())
  userId    String?
  category  String   // UI | API | SYSTEM
  event     String   // Clicks, Errors, AI_Metrics etc.
  meta      Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([category, event])
  @@index([createdAt])
}


model ShoppingListItem {
  id        String   @id @default(cuid())
  userId    String
  name      String
  quantity  Float    @default(1)
  unit      String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId], map: "idx_shoppinglistitem_userid")
  @@index([userId, checked], map: "idx_shoppinglistitem_userid_checked")
  @@index([userId, createdAt], map: "idx_shoppinglistitem_userid_createdat")
}

model UserPreferences {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  cookingSkill             String   @default("intermediate")
  comfortableMethods       String[] @default([])
  avoidMethods             String[] @default([])
  kitchenEquipment         String[] @default([])
  implicitIngredients      String[] @default(["水", "塩", "砂糖", "醤油", "味噌", "油", "米", "小麦粉"])
  enableExpirationAlert    Boolean  @default(true)
  alertDaysBefore          Int      @default(3)
  alertTime                String   @default("07:00")
  expirationCriticalDays   Int      @default(2)
  expirationWarningDays    Int      @default(5)
  expirationPriorityWeight Float    @default(0.7)
  tasteJson                Json     @default("{}")
  aiMessageEnabled         Boolean  @default(false)
  proFeaturesUnlocked      Boolean  @default(false)
  customImplicitIngredients String[] @default([])
  createdAt                DateTime @default(now())
  updatedAt                DateTime @default(now()) @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model UserAllergy {
  id        String   @id @default(cuid())
  userId    String
  allergen  String
  label     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRestriction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyMenuGeneration {
  id                       String   @id @default(cuid())
  userId                   String
  startDate                DateTime
  endDate                  DateTime
  dailyMenus               Json
  consolidatedShoppingList Json
  createdAt                DateTime @default(now())
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MenuGeneration {
  id              String           @id @default(cuid())
  userId          String
  householdId     String?          // 追加: 世帯単位の集計用（nullable for migration）
  status          String           @default("completed")
  progressStep    String           @default("preparing")
  mainMenu        Json
  alternativeA    Json
  selectedMenu    String?
  usedIngredients Json
  shoppingList    Json
  generatedAt     DateTime         @default(now())
  difficulty      Int?
  nutritionInfo   Json?
  servings        Int              @default(1)
  budget          Int?
  requestHash     String
  cookingHistory  CookingHistory[]
  tasteEvents   TasteEvent[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  thoughts            Json?
  tasteProfileSnapshot Json?        

  @@index([userId, generatedAt])
  @@index([status], map: "idx_menugeneration_status")
  @@index([progressStep], map: "idx_menugeneration_progress")
  @@index([householdId])           // 追加: 世帯検索用
}

model CookingHistory {
  id               String          @id @default(cuid())
  userId           String
  menuGenerationId String?
  status           String          @default("completed")
  cookedAt         DateTime        @default(now())
  cookedDishes     Json
  usedIngredients  Json
  cancellableUntil DateTime
  menuGeneration   MenuGeneration? @relation(fields: [menuGenerationId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, cookedAt])
}

model InventoryAlert {
  id            String     @id @default(cuid())
  userId        String
  ingredientId  String
  alertType     String
  alertDays     Int        @default(3)
  lastAlertedAt DateTime?
  createdAt     DateTime   @default(now())
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ingredientId, alertType])
  @@unique([userId, ingredientId, alertType], map: "ux_inventoryalert_user_ingredient_alerttype")
}

model Receipt {
  id             String        @id @default(cuid())
  householdId    String?       // nullable: FREEプランのユーザーはHouseholdを持たない
  uploadedBy     String
  status         String        @default("uploaded")
  rawText        String?
  parsedAt       DateTime?
  confirmedAt    DateTime?
  idempotencyKey String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  household      Household?    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  items          ReceiptItem[]

  @@index([householdId])
  @@index([uploadedBy])
  @@index([status])
  @@index([idempotencyKey])
}

model ReceiptItem {
  id                      String      @id @default(cuid())
  receiptId               String
  lineText                String
  productName             String?
  normalizedName          String?
  mappedIngredientId      String?
  quantityValue           Float?
  quantityUnit            String?
  inferredLevel           String?
  processedCategory       String?
  confidenceScore         Float?
  createdAt               DateTime    @default(now())
  estimatedExpirationDays Int?
  mappedIngredient        Ingredient? @relation(fields: [mappedIngredientId], references: [id])
  receipt                 Receipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([mappedIngredientId])
}


model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
}

// 好み学習イベントテーブル（3軸データ構造対応）
model TasteEvent {
  id                String   @id @default(cuid())
  userId            String
  householdId       String?
  mealPlanResultId  String?
  
  // 3軸データ構造
  ingredientKey     String?  // 食材（正規化済み）
  dishName          String?  // 料理名
  cookingMethod     String?  // 調理法（焼き・煮る・蒸すなど）
  
  // 3段階評価: want_again（また作りたい）| okay（まあまあ）| never_again（もう作らない）
  eventType         String   // 旧: used/skipped/liked/disliked/repeated/removed
  weight            Float    @default(1.0)
  decayFactor       Float    @default(1.0)  // 時間減衰係数（0-1）
  
  source            String   // revisit | swipe | cook | manual | feedback
  createdAt         DateTime @default(now())
  
  // リレーション
  menuGeneration    MenuGeneration? @relation(fields: [mealPlanResultId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([householdId, createdAt])
  @@index([ingredientKey])
  @@index([dishName])
  @@index([cookingMethod])
  @@index([eventType])
}

// ユーザーターストプロファイルテーブル（3軸データ対応）
model UserTasteProfile {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  householdId               String?

  // 食材嗜好（スコア付きJSON）
  favoriteIngredients       String[] @default([])
  dislikedIngredients       String[] @default([])
  ingredientScores          Json?    // { "人参": 0.8, "納豆": -0.5 }

  // 料理嗜好（スコア付きJSON）
  favoriteDishes            String[] @default([])
  dislikedDishes            String[] @default([])
  dishScores                Json?    // { "カレー": 0.9, "煮物": -0.3 }

  // 調理法嗜好（スコア付きJSON）
  favoriteMethods           String[] @default([])
  dislikedMethods           String[] @default([])
  methodScores              Json?    // { "焼き": 0.7, "蒸し": -0.2 }

  updatedAt                 DateTime @updatedAt
  version                   Int      @default(2)  // v2: 3軸データ構造

  @@index([householdId])
  @@index([updatedAt])
}

// キッチンアシスタントのデイリークォータ管理
model ChatDailyQuota {
  id        String   @id @default(cuid())
  userId    String   @unique
  count     Int      @default(0)  // 今日の使用回数
  resetAt   DateTime @default(now())  // 最後にリセットした日付
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PlanType {
  FREE
  PRO
}

enum IngredientType {
  raw
  processed_base
  instant_complete
}

enum HouseholdRole {
  OWNER
  MEMBER
}
