{
  "crons": [
    {
      "path": "/api/cron/daily-alert",
      "schedule": "0 22 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "functions": {
    "app/api/cron/daily-alert/route.ts": {
      "maxDuration": 30
    },
    "app/api/menu/generate/route.ts": {
      "maxDuration": 60
    }
  },
  "regions": [
    "nrt1"
  ]
}